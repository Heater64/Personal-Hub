rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Usuarios - solo pueden leer/escribir su propio documento
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Decks - solo el dueño
    match /decks/{deckId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Cards - solo el dueño (por userId)
    match /cards/{cardId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Study sessions - solo el dueño
    match /study_sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Colecciones públicas (calendario, maldia, razones)
    match /calendario/{doc} {
      allow read, write: if request.auth != null;
    }
    match /maldia/{doc} {
      allow read, write: if request.auth != null;
    }
    match /razones/{doc} {
      allow read, write: if request.auth != null;
    }
    match /seriesData/{doc} {
      allow read, write: if request.auth != null;
    }
    match /seriesTrackerProgress/{userId}/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
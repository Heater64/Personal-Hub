rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin - solo lectura/escritura para usuarios autenticados
    match /admin/{document} {
      allow read, write: if true;  // En producción, cambia a: request.auth != null
    }
    
    // Calendario
    match /calendario/{document} {
      allow read, write: if true;
    }
    
    // Razones
    match /razones/{document} {
      allow read, write: if true;
    }
    
    // Mal día
    match /maldia/{document} {
      allow read, write: if true;
    }
    
    // Series tracker
    match /seriesTrackerProgress/{userId}/{document} {
      allow read, write: if true;
    }
  }
}
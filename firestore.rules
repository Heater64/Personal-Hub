rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // HELPERS
    // ==========================================
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && request.auth.token.email == 'admin@personalhub.com';
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ==========================================
    // ADMIN — solo admin puede leer/escribir
    // ==========================================
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    // ==========================================
    // USUARIOS — cada uno solo sobre su propio UID
    // ==========================================
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // ==========================================
    // PROGRESO DE SERIES — por usuario
    // ==========================================
    match /seriesTrackerProgress/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // ==========================================
    // CONFIGURACIONES — admin escribe, auth lee
    // ==========================================
    match /config_razones/data {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /config_openwhen/data {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /config_maldia_frases/data {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /config_maldia_mensajes/data {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /config_gifts/catalog {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /config_noticias/data {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /config_canciones_recuerdan/data {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /config_canciones_gustan/data {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /config/sidebar {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /config/podio {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ==========================================
    // CALENDARIO — admin escribe, auth lee
    // ==========================================
    match /calendario/{document=**} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ==========================================
    // SERIES Y PELÍCULAS (biblioteca)
    // ==========================================
    match /seriesData/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ==========================================
    // ESTADÍSTICAS — admin lee, cualquiera escribe
    // ==========================================
    match /stats_visits/{doc} {
      allow read: if isAdmin();
      allow write: if true;
    }

    match /stats_sessions/{doc} {
      allow read: if isAdmin();
      allow write: if true;
    }

    match /stats_admin_actions/{doc} {
      allow read: if isAdmin();
      allow write: if true;
    }

  }
}
